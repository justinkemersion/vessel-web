# Vessel — environment template.
#
# Copy to .env (compose) or .env.local (next dev) and fill in real values.
# .env / .env.local are gitignored. Never commit secrets.

# --- Clerk -------------------------------------------------------------------
# Publishable key — inlined into the client bundle at BUILD time.
# Required by ClerkProvider on every page that uses Clerk hooks.
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_replace_me

# Secret key — server-side only, read at RUNTIME.
# Required by Clerk middleware, server actions, and the Clerk backend SDK.
CLERK_SECRET_KEY=sk_test_replace_me

# --- Runtime -----------------------------------------------------------------
# Host port the container should publish on. The Next.js server inside the
# container always listens on 3000 (see Dockerfile).
PORT=3000
